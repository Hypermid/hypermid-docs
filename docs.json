{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Hypermid",
  "colors": {
    "primary": "#5B3CF5",
    "light": "#7C5CFC",
    "dark": "#5B3CF5"
  },
  "logo": {
    "light": "/branding/wordmark-light.svg",
    "dark": "/branding/wordmark-dark.svg",
    "href": "https://hypermid.io",
    "width": 200
  },
  "favicon": "/branding/favicon.svg",
  "fonts": {
    "heading": {
      "family": "Syne",
      "weight": 600
    },
    "body": {
      "family": "Sora"
    }
  },
  "appearance": {
    "default": "system"
  },
  "background": {
    "decoration": "gradient",
    "light": "#F9F8F5",
    "dark": "#0A0A0A"
  },
  "navbar": {
    "links": [
      { "label": "API Status", "href": "https://api.hypermid.io/v1/ping" }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.hypermid.io"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart", "authentication", "response-format"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/cross-chain-swap",
              "guides/superswap",
              "guides/fiat-onramp",
              "guides/error-handling",
              "guides/webhooks"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/chains",
              "resources/error-codes",
              "resources/changelog",
              "resources/support"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "Discovery",
            "pages": [
              "api-reference/chains",
              "api-reference/tokens",
              "api-reference/connections",
              "api-reference/tools",
              "api-reference/gas-prices"
            ]
          },
          {
            "group": "Swap",
            "pages": [
              "api-reference/quote",
              "api-reference/routes",
              "api-reference/execute",
              "api-reference/register-inbound-receiver",
              "api-reference/status",
              "api-reference/deposit-submit",
              "api-reference/deposit-status"
            ]
          },
          {
            "group": "On-Ramp",
            "pages": [
              "api-reference/onramp-quote",
              "api-reference/onramp-checkout",
              "api-reference/onramp-status",
              "api-reference/onramp-config",
              "api-reference/onramp-assets"
            ]
          },
          {
            "group": "Partner",
            "pages": [
              "api-reference/partner-me",
              "api-reference/partner-stats",
              "api-reference/partner-transactions",
              "api-reference/webhooks-create",
              "api-reference/webhooks-list",
              "api-reference/webhooks-delete",
              "api-reference/swap-event"
            ]
          },
          {
            "group": "System",
            "pages": ["api-reference/ping"]
          }
        ]
      },
      {
        "tab": "Widget Integration",
        "icon": "browser",
        "groups": [
          {
            "group": "Widget Integration",
            "pages": [
              "widget/overview",
              "guides/widget-integration",
              "widget/playground",
              "widget/configuration",
              "widget/events",
              "widget/react"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "icon": "code",
        "pages": ["sdks/overview", "sdks/typescript", "sdks/go", "sdks/rust"]
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/hypermid"
    }
  },
  "api": {
    "baseUrl": "https://api.hypermid.io",
    "auth": {
      "method": "key",
      "name": "X-API-Key"
    },
    "playground": {
      "display": "interactive"
    },
    "openapi": "https://api.hypermid.io/v1/openapi.json"
  }
}
